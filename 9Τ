    <script>
        function localizePricing() {
            const priceElements = document.querySelectorAll('.dynamic-price');
            const currencyNote = document.getElementById('currency-note');
            const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
            
            let price = "5,000 NGN"; 
            let methods = "MTN MoMo, Airtel & Bank Transfer";

            if (timezone.includes('Johannesburg') || timezone.includes('Harare')) {
                price = "100 ZAR";
                methods = "Instant EFT, Card & Capitec Pay";
            } else if (timezone.includes('Nairobi') || timezone.includes('Kampala')) {
                price = "550 KES";
                methods = "M-Pesa & Airtel Money";
            } else if (timezone.includes('Accra')) {
                price = "55 GHS";
                methods = "MTN Mobile Money & Vodafone Cash";
            }

            priceElements.forEach(el => { el.innerText = price; });
            if (currencyNote) {
                currencyNote.innerHTML = `<span class="text-green-500">●</span> Instant Access: ${methods} via Selar`;
            }
        }

        const names = ['Kofi', 'Olatunji', 'Chinedu', 'Blessing', 'Kwame', 'Sani', 'Thabo', 'Lerato'];
        const actions = ['just joined the Alpha Group', 'just hit TP2 on Gold! 🔥', 'just joined the Trial', 'is up 12% this week 📈'];
        
        function showPopup() {
            const name = names[Math.floor(Math.random() * names.length)];
            const action = actions[Math.floor(Math.random() * actions.length)];
            const popup = document.createElement('div');
            popup.className = 'fixed bottom-24 left-4 bg-white/10 backdrop-blur-xl border border-white/20 p-3 rounded-lg z-50 text-[10px] animate-bounce notification-popup';
            popup.innerHTML = `🔥 <strong>${name}</strong> ${action}`;
            document.body.appendChild(popup);
            setTimeout(() => {
                popup.classList.add('opacity-0', 'transition-opacity', 'duration-1000');
                setTimeout(() => popup.remove(), 1000);
            }, 4000);
        }

        window.onload = function() {
            localizePricing();
            setTimeout(() => { showPopup(); setInterval(showPopup, 9000); }, 3000);
        };
    </script>
